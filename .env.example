HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Bu sunucunun kendi public adresi. Posnet'in 3D Secure sonrası POST ile geri
# döneceği merchantReturnURL bu adresten türetilir (BACKEND_URL + /api/payment/callback).
BACKEND_URL=

# Ödeme sonucunda kullanıcının yönlendirileceği frontend adresi
# (BACKEND_URL + /payment/success?order=... veya /payment/failure?order=...&reason=...)
FRONTEND_URL=

# Yapı Kredi Posnet (Sanal POS) - değerler İşyeri Yönetici Ekranları / Posnet Support
# tarafından sağlanır. GERÇEK DEĞERLERİ BURAYA YAZMAYIN, sadece .env dosyanıza girin.
POSNET_MERCHANT_ID=
POSNET_TERMINAL_ID=
POSNET_ID=
POSNET_ENCKEY=

# Test ortamı: https://setmpos.ykb.com/PosnetWebService/XML
# Canlı ortam: https://posnet.yapikredi.com.tr/PosnetWebService/XML
POSNET_XML_URL=

# Test ortamı: https://setmpos.ykb.com/3DSWebService/YKBPaymentService
# Canlı ortam: https://posnet.yapikredi.com.tr/3DSWebService/YKBPaymentService
POSNET_OOS_URL=
